# ─────────────────────────────────────────────────────────────────
# Jarvis .env — local configuration (never commit this file)
#
# Copy .env.example to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# AI Hack Club API (OpenAI-compatible, no key required)
HACKCLUB_AI_BASE_URL=https://ai.hackclub.com/proxy/v1
JARVIS_CHAT_MODEL=qwen/qwen3-32b
JARVIS_CODE_MODEL=qwen/qwen3-32b

# Recording duration in seconds
JARVIS_RECORD_SECONDS=8