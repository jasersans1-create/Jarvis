# ─────────────────────────────────────────────────────────────────
# Jarvis Environment Configuration
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── AI Hack Club API ─────────────────────────────────────────────
# The AI Hack Club API is an OpenAI-compatible API hosted at:
#   https://ai.hackclub.com
#
# No API key is required for open access.
# If the API begins requiring authentication in the future, set this:
# HACKCLUB_AI_API_KEY=your_key_here

# Base URL for the AI Hack Club API (do not change unless self-hosting)
HACKCLUB_AI_BASE_URL=https://ai.hackclub.com/proxy/v1

# Model used for general conversation
# Available models: qwen/qwen3-32b, google/gemini-2.5-flash, gpt-5-mini, etc.
JARVIS_CHAT_MODEL=qwen/qwen3-32b

# Model used for code generation
JARVIS_CODE_MODEL=qwen/qwen3-32b

# ── Voice / TTS ───────────────────────────────────────────────────
# Path to the Piper TTS binary (auto-detected from .venv if not set)
# JARVIS_PIPER_BIN=/path/to/piper

# Path to the Piper voice model (.onnx file)
# Download from: https://huggingface.co/rhasspy/piper-voices
# JARVIS_VOICE_MODEL=/path/to/en_US-hfc_male-medium.onnx

# Temporary WAV file for TTS output
# JARVIS_TTS_TMPFILE=/tmp/jarvis.wav

# ── Microphone & STT ──────────────────────────────────────────────
# Device index for the microphone (leave unset to use system default)
# Run: python -c "import sounddevice; print(sounddevice.query_devices())"
# JARVIS_MIC_INDEX=0

# How many seconds to record per utterance
JARVIS_RECORD_SECONDS=8

# Force offline Speech-to-Text (STT) using Vosk instead of Google Online STT
# JARVIS_STT_OFFLINE=false

# Path to the Vosk speech recognition model directory (offline STT)
# JARVIS_VOSK_MODEL=./vosk-model/vosk-model-small-en-us-0.15

# ── Music ─────────────────────────────────────────────────────────
# YouTube playlist or video URL to open when you say "play music"
# JARVIS_MUSIC_PLAYLIST=https://www.youtube.com/watch?v=jfKfPfyJRdk

# Browser command override (auto-detected if not set)
# JARVIS_BROWSER=google-chrome-stable

# ── Workspaces ────────────────────────────────────────────────────
# Base directory where named workspaces are created
# JARVIS_WORKSPACES_DIR=~/Workspaces

# ── Code Generation ───────────────────────────────────────────────
# Directory where generated code files are saved
# JARVIS_GENERATED_DIR=./generated

# ── Wake Word ─────────────────────────────────────────────────────
# Confidence threshold for openwakeword detection (0.0–1.0)
# JARVIS_WAKE_THRESHOLD=0.5
